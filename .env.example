# Code-Sandbox 环境变量配置

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 执行超时（秒）
SANDBOX_TIMEOUT=30

# 内存限制（MB）
MAX_MEMORY_MB=512

# 是否启用缓存
ENABLE_CACHE=true

# 缓存最大条目数
CACHE_MAX_SIZE=1000

# 缓存 TTL（秒）
CACHE_TTL=3600

# 拦截的模块（逗号分隔）
BLOCKED_MODULES=os,subprocess,sys,builtins,ctypes,socket,pickle,shelve

# 允许的模块（留空表示使用拦截列表，否则使用白名单模式）
# ALLOWED_MODULES=
