# Code-Sandbox 环境变量配置

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 执行超时（秒）
SANDBOX_TIMEOUT=30

# 内存限制（MB）
MAX_MEMORY_MB=512

# 是否启用缓存
ENABLE_CACHE=true

# 缓存最大条目数
CACHE_MAX_SIZE=1000

# 缓存 TTL（秒）
CACHE_TTL=3600

# 注意：拦截模块需要在代码中配置 (src/sandbox/types.py)
# 当前默认拦截：os, subprocess, sys, builtins, ctypes, socket, pickle, shelve
