# Code-Sandbox 环境变量配置

# MCP 传输模式：stdio (默认) 或 http
# stdio: 本地 Docker/LLM 集成（推荐）
# http: 远程 HTTP/SSE 流式访问
MCP_TRANSPORT=stdio

# HTTP 模式配置（仅当 MCP_TRANSPORT=http 时使用）
MCP_HOST=0.0.0.0
MCP_PORT=8765  # 使用不常用端口，避免冲突（用于 docker-compose ports 映射）

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 执行超时（秒）
SANDBOX_TIMEOUT=30

# 内存限制（MB）
MAX_MEMORY_MB=512

# 是否启用缓存
ENABLE_CACHE=true

# 缓存最大条目数
CACHE_MAX_SIZE=1000

# 缓存 TTL（秒）
CACHE_TTL=3600

# 注意：拦截模块需要在代码中配置 (src/sandbox/types.py)
# 当前默认拦截：os, subprocess, sys, builtins, ctypes, socket, pickle, shelve
